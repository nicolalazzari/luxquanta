# --- Password wall (set on Vercel → Environment Variables) ---
# If neither PASSWORD nor DECK_PASSWORD is set, the site stays public.

# Login passphrase (what you type on /login.html)
PASSWORD=your-shared-passphrase

# Secret used to sign the session cookie (HMAC). Use a long random string in production.
# If omitted, PASSWORD is used (same as legacy behaviour).
CLIENT_KEY=long-random-string-optional

# Legacy aliases (optional — only if you prefer old names):
# DECK_PASSWORD=
# DECK_AUTH_SECRET=
